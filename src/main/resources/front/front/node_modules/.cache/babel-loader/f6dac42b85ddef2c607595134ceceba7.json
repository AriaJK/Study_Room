{"remainingRequest":"D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\node_modules\\babel-loader\\lib\\index.js!D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\src\\pages\\yuyuexinxi\\detail.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\src\\pages\\yuyuexinxi\\detail.vue","mtime":1776150068371},{"path":"D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\babel.config.js","mtime":1776147554453},{"path":"D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1776150064988},{"path":"D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\node_modules\\babel-loader\\lib\\index.js","mtime":1776150064751},{"path":"D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1776150064988},{"path":"D:\\NBU\\junior\\1\\software engineering\\study_room\\src\\main\\resources\\front\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1776150068081}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["CountDown","data","tablename","baseUrl","breadcrumbItem","name","title","detailBanner","endTime","detail","activeName","total","pageSize","pageSizes","totalPage","rules","content","required","message","trigger","buynumber","sfshVisiable","shForm","sfsh","shhf","created","init","methods","goBack","$router","push","$config","$route","query","detailObj","JSON","parse","id","$http","get","then","res","code","mingcheng","$forceUpdate","catch","err","console","error","onAcross","acrossTable","crossOptAudit","statusColumnName","tips","statusColumnValue","localStorage","setItem","stringify","startsWith","obj","getItem","o","$message","type","duration","path","onSH","shHandler","$confirm","confirmButtonText","cancelButtonText","post","curChange","page","getDiscussList","prevClick","nextClick","download","file","window","open","isAuth","components"],"sources":["src/pages/yuyuexinxi/detail.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div :style='{\"width\":\"1000px\",\"padding\":\"20px\",\"margin\":\"10px auto\",\"borderRadius\":\"8px\",\"background\":\"#f8f9fa\",\"boxShadow\":\"0 1px 6px rgba(0, 0, 0, .08)\"}' class=\"breadcrumb-preview\">\r\n      <el-breadcrumb :separator=\"'/'\" :style='{\"fontSize\":\"14px\",\"lineHeight\":\"1\",\"color\":\"#333\"}'>\r\n        <el-breadcrumb-item>首页</el-breadcrumb-item>\r\n        <el-breadcrumb-item v-for=\"(item, index) in breadcrumbItem\" :key=\"index\">{{item.name}}</el-breadcrumb-item>\r\n      </el-breadcrumb>\r\n    </div>\r\n\r\n    <div class=\"detail-preview\" :style='{\"minHeight\":\"600px\",\"width\":\"1000px\",\"margin\":\"10px auto\",\"position\":\"relative\",\"height\":\"auto\"}'>\r\n      <div class=\"attr\" :style='{\"minHeight\":\"400px\",\"padding\":\"20px\",\"position\":\"relative\",\"background\":\"#fff\",\"display\":\"flex\",\"borderRadius\":\"8px\",\"boxShadow\":\"0 1px 6px rgba(0, 0, 0, .08)\"}'>\r\n        <div class=\"info\" :style='{\"width\":\"100%\",\"padding\":\"20px\",\"background\":\"#f8f9fa\",\"borderRadius\":\"8px\"}'>\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>预约单号</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.yuyuedanhao}}</div>\r\n          </div>\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>名称</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.mingcheng}}</div>\r\n          </div>\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>座位</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.zuowei}}</div>\r\n          </div>\r\n\r\n          <!-- 预约开始时间 -->\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>预约开始时间</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.yuyueStart || '-'}}</div>\r\n          </div>\r\n          <!-- 预约结束时间 -->\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>预约结束时间</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.yuyueEnd || '-'}}</div>\r\n          </div>\r\n\r\n          <!-- 新增显示：签到时间 -->\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>签到时间</div>\r\n            <div :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{ detail.qiandaoshijian || '-' }}</div>\r\n          </div>\r\n\r\n          <!-- 新增显示：签退时间 -->\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>签退时间</div>\r\n            <div :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{ detail.qiantuishijian || '-' }}</div>\r\n          </div>\r\n\r\n          <!-- 新增显示：自习时长（分钟） -->\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>自习时长min</div>\r\n            <div :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{ detail.zixishichang != null ? detail.zixishichang : '-' }}</div>\r\n          </div>\r\n\r\n          <!-- 是否违规：使用数据库字段 weiguiFlag / weigui_flag 显示 -->\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>是否违约</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>\r\n              {{ (detail.weiguiFlag === 1 || detail.weigui_flag === 1) ? '已违约' : '未违约' }}\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>备注</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.beizhu && detail.beizhu.trim() !== '' ? detail.beizhu : '无备注'}}</div>\r\n          </div>\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>学号</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.xuehao}}</div>\r\n          </div>\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>姓名</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.xingming}}</div>\r\n          </div>\r\n          <div class=\"item\" :style='{\"padding\":\"12px 16px\",\"margin\":\"0 0 12px 0\",\"background\":\"#fff\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"borderRadius\":\"4px\",\"boxShadow\":\"0 1px 3px rgba(0, 0, 0, .05)\"}'>\r\n            <div class=\"lable\" :style='{\"padding\":\"0 16px 0 0\",\"color\":\"#333\",\"textAlign\":\"right\",\"width\":\"100px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"height\":\"24px\",\"fontWeight\":\"500\"}'>手机</div>\r\n            <div  :style='{\"flex\":1,\"padding\":\"0 16px\",\"fontSize\":\"14px\",\"lineHeight\":\"24px\",\"color\":\"#666\",\"height\":\"24px\"}'>{{detail.shouji}}</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 返回按钮区域 -->\r\n      <div style=\"width: 100%; display: flex; justify-content: center; margin: 30px 0 20px;\">\r\n        <el-button\r\n            :style=\"{\r\n              border: '0',\r\n              cursor: 'pointer',\r\n              padding: '0 24px',\r\n              outline: 'none',\r\n              color: '#fff',\r\n              borderRadius: '4px',\r\n              background: '#6c757d',\r\n              width: 'auto',\r\n              lineHeight: '40px',\r\n              fontSize: '14px',\r\n              height: '40px',\r\n              transition: 'all 0.2s ease'\r\n            }\"\r\n            @click=\"goBack\"\r\n        >\r\n          <i class=\"el-icon-arrow-left\" style=\"margin-right: 6px;\"></i>返回预约列表\r\n        </el-button>\r\n      </div>\r\n\r\n      <el-dialog title=\"审核\" :visible.sync=\"sfshVisiable\" width=\"50%\" :style=\"{borderRadius:'8px'}\">\r\n        <el-form ref=\"shForm\" :model=\"shForm\" label-width=\"80px\">\r\n          <el-form-item label=\"审核状态\">\r\n            <el-select v-model=\"shForm.sfsh\" placeholder=\"审核状态\" :style=\"{borderRadius:'4px'}\">\r\n              <el-option label=\"通过\" value=\"是\"></el-option>\r\n              <el-option label=\"不通过\" value=\"否\"></el-option>\r\n              <el-option label=\"待审核\" value=\"待审核\"></el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n          <el-form-item label=\"内容\">\r\n            <el-input type=\"textarea\" :rows=\"8\" v-model=\"shForm.shhf\" :style=\"{borderRadius:'4px'}\"></el-input>\r\n          </el-form-item>\r\n        </el-form>\r\n        <div slot=\"footer\" class=\"dialog-footer\">\r\n          <el-button @click=\"sfshVisiable = false\" :style=\"{borderRadius:'4px'}\">取 消</el-button>\r\n          <el-button type=\"primary\" @click=\"shHandler\" :style=\"{borderRadius:'4px',background:'#2E61E1',border:'none'}\">确 定</el-button>\r\n        </div>\r\n      </el-dialog>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport CountDown from '@/components/CountDown';\r\nexport default {\r\n  data() {\r\n    return {\r\n      tablename: 'yuyuexinxi',\r\n      baseUrl: '',\r\n      breadcrumbItem: [\r\n        {\r\n          name: '详情信息'\r\n        }\r\n      ],\r\n      title: '',\r\n      detailBanner: [],\r\n      endTime: 0,\r\n      detail: {},\r\n      activeName: 'first',\r\n      total: 1,\r\n      pageSize: 5,\r\n      pageSizes: [10,20,30,50],\r\n      totalPage: 1,\r\n      rules: {\r\n        content: [\r\n          { required: true, message: '请输入内容', trigger: 'blur' }\r\n        ]\r\n      },\r\n      buynumber: 1,\r\n      sfshVisiable: false,\r\n      shForm: {\r\n        sfsh: '是',\r\n        shhf: ''\r\n      },\r\n    }\r\n  },\r\n  created() {\r\n    this.init();\r\n  },\r\n  methods: {\r\n    // 已删除：formatDate时间格式化方法\r\n    goBack() {\r\n      this.$router.push('/index/yuyuexinxi');\r\n    },\r\n    init() {\r\n      this.baseUrl = this.$config.baseUrl;\r\n      if(this.$route.query.detailObj) {\r\n        this.detail = JSON.parse(this.$route.query.detailObj);\r\n      }\r\n      // 请求后端 detail 获取最新字段（包含 weigui_flag、beizhu 等）\r\n      if (this.detail && this.detail.id) {\r\n        this.$http.get(this.tablename + '/detail/'  + this.detail.id, {}).then(res => {\r\n          if (res.data.code == 0) {\r\n            this.detail = res.data.data;\r\n            this.title = this.detail.mingcheng; // 替换原qiandaozhuangtai，避免空值报错\r\n            this.$forceUpdate();\r\n          }\r\n        }).catch(err => {\r\n          console.error('获取详情失败：', err);\r\n        });\r\n      }\r\n    },\r\n    onAcross(acrossTable,crossOptAudit,statusColumnName,tips,statusColumnValue){\r\n      localStorage.setItem('crossTable',`yuyuexinxi`);\r\n      localStorage.setItem('crossObj', JSON.stringify(this.detail));\r\n      localStorage.setItem('statusColumnName',statusColumnName);\r\n      localStorage.setItem('statusColumnValue',statusColumnValue);\r\n      localStorage.setItem('tips',tips);\r\n      if(statusColumnName!=''&&!statusColumnName.startsWith(\"[\")) {\r\n        var obj = JSON.parse(localStorage.getItem('crossObj'));\r\n        for (var o in obj){\r\n          if(o==statusColumnName && obj[o]==statusColumnValue){\r\n            this.$message({\r\n              type: 'success',\r\n              message: tips,\r\n              duration: 1500\r\n            });\r\n            return\r\n          }\r\n        }\r\n      }\r\n      this.$router.push({path: '/index/' + acrossTable + 'Add', query: {type: 'cross'}});\r\n    },\r\n    onSH() {\r\n      this.sfshVisiable = true;\r\n    },\r\n    shHandler(){\r\n      this.$confirm(`确定操作?`, \"提示\", {\r\n        confirmButtonText: \"确定\",\r\n        cancelButtonText: \"取消\",\r\n        type: \"warning\"\r\n      }).then(() => {\r\n        this.detail.sfsh = this.shForm.sfsh;\r\n        this.detail.shhf = this.shForm.shhf;\r\n        this.$http.post(`${this.tablename}/update`, this.detail).then(res => {\r\n          if (res.data.code == 0) {\r\n            this.sfshVisiable = false;\r\n            this.$message({\r\n              message: \"操作成功\",\r\n              type: \"success\",\r\n              duration: 1500,\r\n            });\r\n          }\r\n        });\r\n      });\r\n    },\r\n    curChange(page) {\r\n      this.getDiscussList(page);\r\n    },\r\n    prevClick(page) {\r\n      this.getDiscussList(page);\r\n    },\r\n    nextClick(page) {\r\n      this.getDiscussList(page);\r\n    },\r\n    download(file){\r\n      if(!file) {\r\n        this.$message({\r\n          type: 'error',\r\n          message: '文件不存在',\r\n          duration: 1500,\r\n        });\r\n        return;\r\n      }\r\n      window.open(this.baseUrl+file)\r\n    },\r\n    isAuth() {\r\n      return true;\r\n    }\r\n  },\r\n  components: {\r\n    CountDown\r\n  }\r\n}\r\n</script>\r\n\r\n<style rel=\"stylesheet/scss\" lang=\"scss\" scoped>\r\n/* 样式部分保持不变 */\r\n.detail-preview {\r\n  .attr {\r\n  }\r\n}\r\n\r\n// 面包屑样式优化\r\n.breadcrumb-preview .el-breadcrumb >>> .el-breadcrumb__separator {\r\n  margin: 0 8px;\r\n  color: #666;\r\n  font-weight: normal;\r\n}\r\n\r\n.breadcrumb-preview .el-breadcrumb >>> .el-breadcrumb__inner a {\r\n  color: #2e61e1;\r\n  display: inline-block;\r\n  text-decoration: none;\r\n}\r\n\r\n.breadcrumb-preview .el-breadcrumb >>> .el-breadcrumb__inner {\r\n  color: #333;\r\n  display: inline-block;\r\n}\r\n\r\n// 按钮hover效果\r\n.btn >>> .el-button:hover {\r\n  opacity: 0.9;\r\n  transform: translateY(-1px);\r\n}\r\n\r\n// 返回按钮hover效果\r\n::v-deep .el-button:hover {\r\n  opacity: 0.9;\r\n  transform: translateY(-1px);\r\n}\r\n\r\n// 分页样式保持简约风格\r\n.el-pagination >>> .el-pagination__total {\r\n  margin: 0 10px 0 0;\r\n  color: #666;\r\n  font-weight: 400;\r\n  display: inline-block;\r\n  vertical-align: top;\r\n  font-size: 13px;\r\n  line-height: 28px;\r\n  height: 28px;\r\n}\r\n\r\n.el-